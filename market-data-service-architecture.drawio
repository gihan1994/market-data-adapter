          <mxGeometry height="220" width="480" x="890" y="780" as="geometry" />
        </mxCell>
        <mxCell id="lcm" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;verticalAlign=top;align=left;spacingLeft=10;" value="&lt;b&gt;📡  LCM MS&lt;/b&gt;&#xa;(business consumer)&#xa;&#xa;Sends:    subscribe / unsubscribe requests&#xa;Receives: live ticks + gap events" vertex="1">
          <mxGeometry height="220" width="540" x="1400" y="780" as="geometry" />
        </mxCell>
        <mxCell id="billing" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;align=left;spacingLeft=10;verticalAlign=top;" value="&lt;b&gt;💰 DACS billing&lt;/b&gt;&#xa;Per-DACS-user — 1 named user license.&#xa;ALL pods log in with the same DACS username.&#xa;Active concurrent sessions: &lt;b&gt;2&lt;/b&gt; (active + warm).&#xa;Set DACS MaxLogins ≥ 3 (allows overlap during failover)." vertex="1">
          <mxGeometry height="160" width="620" x="40" y="1030" as="geometry" />
        </mxCell>
        <mxCell id="failover_note" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;align=left;spacingLeft=10;verticalAlign=top;" value="&lt;b&gt;⚡ Failover timing&lt;/b&gt;&#xa;&lt;b&gt;TREP-LB backend failover (LB drops one IP):&lt;/b&gt; transparent to clients via EMA ChannelSet; same DACS session.&#xa;&lt;b&gt;Within-hall pod failure (warm → cold):&lt;/b&gt; ~10–15s; cold pod opens new DACS session.&#xa;&lt;b&gt;Cross-hall failover (hall1 → hall2):&lt;/b&gt; ~5–7s; hall2 warm pod already has DACS session #2 — sends batch ReqMsg." vertex="1">
          <mxGeometry height="160" width="660" x="680" y="1030" as="geometry" />
        </mxCell>
        <mxCell id="legend" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f9f9f9;strokeColor=#333333;fontSize=10;align=left;spacingLeft=10;verticalAlign=top;" value="&lt;b&gt;Legend&lt;/b&gt;&#xa;━━ thick green   Active DACS session #1 (subscribed)&#xa;━━ thick orange  Warm DACS session #2 (idle, no subs)&#xa;┄┄ dashed        Leader-lock watch&#xa;━━ solid         Leader-lock acquire + heartbeat&#xa;━━ purple        Kafka tick / control flow&#xa;🟢 active leader   🟡 warm standby   ⚪ cold standby" vertex="1">
          <mxGeometry height="160" width="580" x="1360" y="1030" as="geometry" />
        </mxCell>
