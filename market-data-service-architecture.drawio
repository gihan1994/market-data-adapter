        <mxCell id="p_h2_warm" value="&lt;b&gt;hall2/pod-0&lt;/b&gt;&#xa;(WARM STANDBY)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="750" y="80" width="160" height="50" as="geometry" />
        </mxCell>
        <mxCell id="p_ads_h2" value="&lt;b&gt;ADS — Hall 2&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="980" y="80" width="160" height="50" as="geometry" />
        </mxCell>
        <mxCell id="p_pg" value="&lt;b&gt;PostgreSQL&lt;/b&gt;&#xa;ric_registry" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="1210" y="80" width="160" height="50" as="geometry" />
