        <mxCell id="p_kctrl" value="&lt;b&gt;Kafka&lt;/b&gt;&#xa;market-data-control" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="1440" y="80" width="160" height="50" as="geometry" />
