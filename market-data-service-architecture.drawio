        <mxCell id="f_m3" edge="1" parent="1" style="endArrow=classic;html=1;fontSize=10;strokeColor=#b85450;fontStyle=1;" value="&lt;b&gt;3.&lt;/b&gt; t=5s — leader:lock TTL expires (key auto-deleted)">
