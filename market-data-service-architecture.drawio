          <mxGeometry height="35" width="1480" x="100" y="545" as="geometry" />
        </mxCell>
        <mxCell id="f_m8" edge="1" parent="1" style="endArrow=classic;html=1;fontSize=10;strokeColor=#82b366;strokeWidth=2;" value="&lt;b&gt;8.&lt;/b&gt; ReqMsg batch for all RICs  →  send via existing OmmConsumer">
