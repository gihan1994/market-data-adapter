        <mxCell id="m1" value="&lt;b&gt;1.&lt;/b&gt; renew leader:lock value=&quot;hall1/market-data-service-0&quot; (every 2s)" style="endArrow=classic;html=1;fontSize=10;strokeColor=#82b366;" edge="1" parent="1">
          <mxGeometry as="geometry">
            <mxPoint x="140" y="175" as="sourcePoint" />
            <mxPoint x="600" y="175" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="m2" value="&lt;b&gt;2.&lt;/b&gt; live ticks: UpdateMsg" style="endArrow=classic;html=1;fontSize=10;strokeColor=#6c8ebf;dashed=1;" edge="1" parent="1">
          <mxGeometry as="geometry">
            <mxPoint x="370" y="215" as="sourcePoint" />
            <mxPoint x="140" y="215" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="m3" value="&lt;b&gt;3.&lt;/b&gt; publish ticks to Kafka" style="endArrow=classic;html=1;fontSize=10;strokeColor=#d79b00;strokeWidth=2;" edge="1" parent="1">
          <mxGeometry as="geometry">
            <mxPoint x="140" y="255" as="sourcePoint" />
            <mxPoint x="1750" y="255" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="disaster" value="&lt;b&gt;💥 t = 0s — Hall 1 catastrophic outage&lt;/b&gt;&#xa;DC power failure / WAN partition / OpenShift cluster down.&#xa;hall1/pod-0 process terminates abruptly; TCP to ADS-Hall1 resets.&#xa;Cross-hall network blocks: hall1 pods unreachable from hall2." style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;align=center;verticalAlign=middle;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="295" width="1800" height="75" as="geometry" />
        </mxCell>
        <mxCell id="m4" value="&lt;b&gt;4.&lt;/b&gt; ❌ heartbeat STOPS (hall1/pod-0 dead, redis unreachable from hall1 too)" style="endArrow=classic;html=1;fontSize=10;strokeColor=#b85450;dashed=1;strokeWidth=2;" edge="1" parent="1">
          <mxGeometry as="geometry">
            <mxPoint x="140" y="395" as="sourcePoint" />
            <mxPoint x="600" y="395" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="wait_band" value="&lt;b&gt;⏱ t = 0–5s&lt;/b&gt;  Enterprise Redis lock TTL counts down (5s). Hall2 pods are spinning, attempting SETNX every heartbeat tick (2s)." style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;align=center;verticalAlign=middle;fontStyle=2;" vertex="1" parent="1">
          <mxGeometry x="40" y="425" width="1800" height="35" as="geometry" />
        </mxCell>
        <mxCell id="m5" value="&lt;b&gt;5.&lt;/b&gt; t=5s — leader:lock TTL expires (key auto-deleted by Redis)" style="endArrow=classic;html=1;fontSize=10;strokeColor=#b85450;fontStyle=1;" edge="1" parent="1">
          <mxGeometry as="geometry">
            <mxPoint x="600" y="475" as="sourcePoint" />
            <mxPoint x="700" y="475" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="m6" value="&lt;b&gt;6.&lt;/b&gt; SETNX leader:lock &quot;hall2/market-data-service-0&quot; EX 5  →  OK (won election)" style="endArrow=classic;html=1;fontSize=10;strokeColor=#d6b656;strokeWidth=2;" edge="1" parent="1">
          <mxGeometry as="geometry">
            <mxPoint x="830" y="510" as="sourcePoint" />
            <mxPoint x="600" y="510" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="m7" value="&lt;b&gt;7.&lt;/b&gt; PromotedToLeaderEvent fires in Spring context (cross-hall promotion!)" style="endArrow=classic;html=1;fontSize=10;strokeColor=#d6b656;fontStyle=2;" edge="1" parent="1">
          <mxGeometry as="geometry">
            <mxPoint x="830" y="545" as="sourcePoint" />
            <mxPoint x="940" y="545" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="note_warm" value="&lt;b&gt;⚡ Key point: hall2/pod-0 already has an open DACS session #2 to ADS-Hall2. No new DACS login needed — just send ReqMsg.&lt;/b&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;align=center;verticalAlign=middle;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="585" width="1800" height="35" as="geometry" />
        </mxCell>
        <mxCell id="m8" value="&lt;b&gt;8.&lt;/b&gt; SELECT ric FROM ric_registry WHERE active=true" style="endArrow=classic;html=1;fontSize=10;strokeColor=#6c8ebf;" edge="1" parent="1">
          <mxGeometry as="geometry">
            <mxPoint x="830" y="645" as="sourcePoint" />
            <mxPoint x="1290" y="645" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="m9" value="&lt;b&gt;9.&lt;/b&gt; [EUR=, GBP=, USDJPY=, ...]  (all RICs)" style="endArrow=classic;html=1;fontSize=10;strokeColor=#6c8ebf;dashed=1;" edge="1" parent="1">
          <mxGeometry as="geometry">
            <mxPoint x="1290" y="685" as="sourcePoint" />
            <mxPoint x="830" y="685" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="m10" value="&lt;b&gt;10.&lt;/b&gt; batch ReqMsg for all RICs via existing OmmConsumer (DACS session #2)" style="endArrow=classic;html=1;fontSize=10;strokeColor=#82b366;strokeWidth=2;" edge="1" parent="1">
          <mxGeometry as="geometry">
            <mxPoint x="830" y="725" as="sourcePoint" />
            <mxPoint x="1060" y="725" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="m11" value="&lt;b&gt;11.&lt;/b&gt; RefreshMsg snapshots for each RIC (current bid/ask)" style="endArrow=classic;html=1;fontSize=10;strokeColor=#6c8ebf;dashed=1;strokeWidth=2;" edge="1" parent="1">
          <mxGeometry as="geometry">
            <mxPoint x="1060" y="765" as="sourcePoint" />
            <mxPoint x="830" y="765" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="m12" value="&lt;b&gt;12.&lt;/b&gt; for each RIC: GET ric:last-published:{ric}  →  compute gap window" style="endArrow=classic;html=1;fontSize=10;strokeColor=#d6b656;" edge="1" parent="1">
          <mxGeometry as="geometry">
            <mxPoint x="830" y="805" as="sourcePoint" />
            <mxPoint x="600" y="805" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="m13" value="&lt;b&gt;13.&lt;/b&gt; publish GAP_DETECTED { ric, gap_start, gap_end, new_leader:&quot;hall2/pod-0&quot;, cross_hall_failover:true }" style="endArrow=classic;html=1;fontSize=10;strokeColor=#d79b00;strokeWidth=2;" edge="1" parent="1">
          <mxGeometry as="geometry">
            <mxPoint x="830" y="845" as="sourcePoint" />
            <mxPoint x="1520" y="845" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="m14" value="&lt;b&gt;14.&lt;/b&gt; publish snapshot tick per RIC → market-data-updates" style="endArrow=classic;html=1;fontSize=10;strokeColor=#d79b00;strokeWidth=2;" edge="1" parent="1">
          <mxGeometry as="geometry">
            <mxPoint x="830" y="885" as="sourcePoint" />
            <mxPoint x="1750" y="885" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="recovered" value="&lt;b&gt;✅ t ≈ 5–7s — hall2/pod-0 is now the global leader. Hall1 is offline but the system is recovered.&lt;/b&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;align=center;verticalAlign=middle;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="925" width="1800" height="35" as="geometry" />
        </mxCell>
        <mxCell id="m15" value="&lt;b&gt;15.&lt;/b&gt; ongoing: live UpdateMsg from ADS-Hall2" style="endArrow=classic;html=1;fontSize=10;strokeColor=#6c8ebf;dashed=1;" edge="1" parent="1">
          <mxGeometry as="geometry">
            <mxPoint x="1060" y="985" as="sourcePoint" />
            <mxPoint x="830" y="985" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="m16" value="&lt;b&gt;16.&lt;/b&gt; ongoing: hall2/pod-0 publishes ticks; renews lock; hall1/pod-1 remains down" style="endArrow=classic;html=1;fontSize=10;strokeColor=#d79b00;strokeWidth=2;" edge="1" parent="1">
          <mxGeometry as="geometry">
            <mxPoint x="830" y="1025" as="sourcePoint" />
            <mxPoint x="1750" y="1025" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="hall1_back" value="&lt;b&gt;📢 When Hall 1 recovers:&lt;/b&gt; hall1 pods restart and join the lock-watch loop. hall1/pod-0 becomes the new WARM STANDBY (the role of hall2/pod-0 — they swap roles). NO automatic fail-back. Hall2 remains leader until it&#39;s lost again." style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;align=center;verticalAlign=middle;fontStyle=2;" vertex="1" parent="1">
          <mxGeometry x="40" y="1080" width="1800" height="55" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
