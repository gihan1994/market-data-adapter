        <mxCell id="u_m8" edge="1" parent="1" style="endArrow=classic;dashed=1;html=1;fontSize=10;strokeColor=#6c8ebf;" value="&lt;b&gt;9.&lt;/b&gt; Status code &quot;Closed&quot; ack">
          <mxGeometry as="geometry">
            <mxPoint x="1220" y="550" as="sourcePoint" />
            <mxPoint x="560" y="550" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="t_title" parent="1" style="text;html=1;align=left;verticalAlign=middle;fontSize=12;spacingLeft=10;fontStyle=1;" value="&lt;b&gt;B. OAuth2 Token Refresh Flow&lt;/b&gt;  —  active leader proactively refreshes token before expiry; both Pod 1 and Pod 2 rotate their EMA session token via Redis" vertex="1">
          <mxGeometry height="30" width="1600" x="40" y="640" as="geometry" />
        </mxCell>
        <mxCell id="r_auth1" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" value="&lt;b&gt;LSEG Auth Service&lt;/b&gt;&#xa;(Pod 1 — leader)" vertex="1">
          <mxGeometry height="50" width="160" x="50" y="680" as="geometry" />
        </mxCell>
        <mxCell id="r_oauth" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" value="&lt;b&gt;LSEG OAuth2&lt;/b&gt;&#xa;Token Endpoint" vertex="1">
          <mxGeometry height="50" width="160" x="290" y="680" as="geometry" />
        </mxCell>
        <mxCell id="r_rds" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" value="&lt;b&gt;Redis&lt;/b&gt;&#xa;lseg:auth:token" vertex="1">
          <mxGeometry height="50" width="160" x="530" y="680" as="geometry" />
        </mxCell>
        <mxCell id="r_omm1" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" value="&lt;b&gt;OmmConsumer&lt;/b&gt;&#xa;(Pod 1 — active)" vertex="1">
          <mxGeometry height="50" width="160" x="770" y="680" as="geometry" />
        </mxCell>
        <mxCell id="r_auth2" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" value="&lt;b&gt;LSEG Auth Service&lt;/b&gt;&#xa;(Pod 2 — warm)" vertex="1">
          <mxGeometry height="50" width="160" x="1010" y="680" as="geometry" />
        </mxCell>
        <mxCell id="r_omm2" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" value="&lt;b&gt;OmmConsumer&lt;/b&gt;&#xa;(Pod 2 — warm)" vertex="1">
          <mxGeometry height="50" width="160" x="1250" y="680" as="geometry" />
        </mxCell>
        <mxCell id="r_ll_auth1" edge="1" parent="1" style="endArrow=none;dashed=1;dashPattern=4 4;strokeColor=#82b366;">
          <mxGeometry as="geometry">
            <mxPoint x="130" y="735" as="sourcePoint" />
            <mxPoint x="130" y="1250" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="r_ll_oauth" edge="1" parent="1" style="endArrow=none;dashed=1;dashPattern=4 4;strokeColor=#6c8ebf;">
          <mxGeometry as="geometry">
            <mxPoint x="370" y="735" as="sourcePoint" />
            <mxPoint x="370" y="1250" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="r_ll_rds" edge="1" parent="1" style="endArrow=none;dashed=1;dashPattern=4 4;strokeColor=#d6b656;strokeWidth=2;">
          <mxGeometry as="geometry">
            <mxPoint x="610" y="735" as="sourcePoint" />
            <mxPoint x="610" y="1250" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="r_ll_omm1" edge="1" parent="1" style="endArrow=none;dashed=1;dashPattern=4 4;strokeColor=#82b366;">
          <mxGeometry as="geometry">
            <mxPoint x="850" y="735" as="sourcePoint" />
            <mxPoint x="850" y="1250" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="r_ll_auth2" edge="1" parent="1" style="endArrow=none;dashed=1;dashPattern=4 4;strokeColor=#d6b656;">
          <mxGeometry as="geometry">
            <mxPoint x="1090" y="735" as="sourcePoint" />
            <mxPoint x="1090" y="1250" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="r_ll_omm2" edge="1" parent="1" style="endArrow=none;dashed=1;dashPattern=4 4;strokeColor=#d6b656;">
          <mxGeometry as="geometry">
            <mxPoint x="1330" y="735" as="sourcePoint" />
            <mxPoint x="1330" y="1250" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="r_trigger" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;align=center;verticalAlign=middle;fontStyle=1;" value="&lt;b&gt;⏰ Scheduled @Scheduled(fixedDelay=60s) — leader checks token TTL&lt;/b&gt;" vertex="1">
          <mxGeometry height="30" width="700" x="50" y="770" as="geometry" />
        </mxCell>
        <mxCell id="r_m1" edge="1" parent="1" style="endArrow=classic;html=1;fontSize=10;strokeColor=#82b366;fontStyle=2;" value="&lt;b&gt;1.&lt;/b&gt; check expiry: token expires in &lt; 5 min  →  proactively refresh">
          <mxGeometry as="geometry">
            <mxPoint x="130" y="820" as="sourcePoint" />
            <mxPoint x="250" y="820" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="r_m2" edge="1" parent="1" style="endArrow=classic;html=1;fontSize=10;strokeColor=#82b366;" value="&lt;b&gt;2.&lt;/b&gt; POST /token  (grant_type=refresh_token, refresh_token=...)">
          <mxGeometry as="geometry">
            <mxPoint x="130" y="860" as="sourcePoint" />
            <mxPoint x="370" y="860" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="r_m3" edge="1" parent="1" style="endArrow=classic;dashed=1;html=1;fontSize=10;strokeColor=#6c8ebf;strokeWidth=2;" value="&lt;b&gt;3.&lt;/b&gt; { access_token: &quot;eyJ...&quot;, expires_in: 3600, refresh_token: &quot;...&quot; }">
          <mxGeometry as="geometry">
            <mxPoint x="370" y="900" as="sourcePoint" />
            <mxPoint x="130" y="900" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="r_m4" edge="1" parent="1" style="endArrow=classic;html=1;fontSize=10;strokeColor=#82b366;strokeWidth=2;" value="&lt;b&gt;4.&lt;/b&gt; SET lseg:auth:token &quot;eyJ...&quot; EX 3540 (~1 min early to allow propagation)">
          <mxGeometry as="geometry">
            <mxPoint x="130" y="945" as="sourcePoint" />
            <mxPoint x="610" y="945" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="r_m5" edge="1" parent="1" style="endArrow=classic;html=1;fontSize=10;strokeColor=#82b366;" value="&lt;b&gt;5.&lt;/b&gt; rotate token on active EMA session&#xa;(EmaConfig.username/password update)">
          <mxGeometry as="geometry">
            <mxPoint x="130" y="990" as="sourcePoint" />
            <mxPoint x="850" y="990" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="r_note" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;align=center;verticalAlign=middle;fontStyle=1;" value="&lt;b&gt;📢 Pod 2 polls Redis every 30s for token changes — or uses Redis pub/sub for instant notification&lt;/b&gt;" vertex="1">
          <mxGeometry height="30" width="800" x="610" y="1030" as="geometry" />
        </mxCell>
        <mxCell id="r_m6" edge="1" parent="1" style="endArrow=classic;html=1;fontSize=10;strokeColor=#d6b656;" value="&lt;b&gt;6.&lt;/b&gt; Pod 2 detects token change  →  GET lseg:auth:token">
          <mxGeometry as="geometry">
            <mxPoint x="1090" y="1080" as="sourcePoint" />
            <mxPoint x="610" y="1080" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="r_m7" edge="1" parent="1" style="endArrow=classic;dashed=1;html=1;fontSize=10;strokeColor=#d6b656;" value="&lt;b&gt;7.&lt;/b&gt; &quot;eyJ...&quot; (new token)">
          <mxGeometry as="geometry">
            <mxPoint x="610" y="1115" as="sourcePoint" />
            <mxPoint x="1090" y="1115" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="r_m8" edge="1" parent="1" style="endArrow=classic;html=1;fontSize=10;strokeColor=#d6b656;strokeWidth=2;" value="&lt;b&gt;8.&lt;/b&gt; rotate token on warm EMA session  →  Pod 2 stays logged-in">
          <mxGeometry as="geometry">
            <mxPoint x="1090" y="1155" as="sourcePoint" />
            <mxPoint x="1330" y="1155" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="r_done" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;align=center;verticalAlign=middle;fontStyle=1;" value="&lt;b&gt;✅ Both EMA sessions now use the refreshed token — no disconnect, no resubscription needed&lt;/b&gt;" vertex="1">
          <mxGeometry height="35" width="1400" x="50" y="1200" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram name="6. Workflow — Subscription Lifecycle" id="fxEQWZ4R2sKZ_4MwYpuz">
    <mxGraphModel dx="2060" dy="1244" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="w6_title" parent="1" style="text;html=1;align=left;verticalAlign=middle;fontSize=14;spacingLeft=10;" value="&lt;b&gt;Workflow — Subscription Lifecycle (state machine per RIC)&lt;/b&gt;&#xa;State is shared across pods via Redis (ric:active) and PostgreSQL (ric_registry); transitions are driven by business MS requests, EMA callbacks, and refcount changes" vertex="1">
          <mxGeometry height="60" width="1300" x="40" y="20" as="geometry" />
        </mxCell>
        <mxCell id="w6_start" parent="1" style="ellipse;whiteSpace=wrap;html=1;fillColor=#000000;strokeColor=#000000;" value="" vertex="1">
          <mxGeometry height="30" width="30" x="628" y="100" as="geometry" />
        </mxCell>
        <mxCell id="w6_req" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;align=center;" value="&lt;b&gt;REQUESTED&lt;/b&gt;&#xa;&#xa;Business MS published&#xa;SUBSCRIBE; refcount incremented&#xa;in Redis and PostgreSQL" vertex="1">
          <mxGeometry height="100" width="436" x="425" y="190" as="geometry" />
        </mxCell>
        <mxCell id="w6_sub" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;align=center;" value="&lt;b&gt;SUBSCRIBING&lt;/b&gt;&#xa;&#xa;ReqMsg sent via EMA;&#xa;awaiting RefreshMsg snapshot" vertex="1">
          <mxGeometry height="100" width="250" x="500" y="370" as="geometry" />
        </mxCell>
        <mxCell id="w6_active" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;align=center;fontStyle=1;" value="&lt;b&gt;ACTIVE&lt;/b&gt;&#xa;&#xa;Live UpdateMsg ticks flowing&#xa;through to market-data-updates;&#xa;cached in ric:price" vertex="1">
          <mxGeometry height="110" width="437" x="418" y="550" as="geometry" />
        </mxCell>
        <mxCell id="w6_drain" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=11;align=center;" value="&lt;b&gt;DRAINING&lt;/b&gt;&#xa;&#xa;refcount reached 0;&#xa;awaiting grace period&#xa;(default 30s) before close" vertex="1">
          <mxGeometry height="100" width="250" x="500" y="740" as="geometry" />
        </mxCell>
        <mxCell id="w6_closed" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=11;align=center;" value="&lt;b&gt;CLOSED&lt;/b&gt;&#xa;&#xa;CloseMsg sent;&#xa;ric_registry.active = false;&#xa;Redis keys purged" vertex="1">
          <mxGeometry height="100" width="250" x="500" y="910" as="geometry" />
        </mxCell>
        <mxCell id="w6_error" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;align=center;" value="&lt;b&gt;ERROR&lt;/b&gt;&#xa;&#xa;LSEG returned StatusMsg:&#xa;DENIED / NOT_FOUND / SUSPECT&#xa;Logged to subscription_audit" vertex="1">
          <mxGeometry height="100" width="250" x="1099" y="370" as="geometry" />
        </mxCell>
        <mxCell id="w6_end" parent="1" style="ellipse;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;strokeWidth=3;" value="" vertex="1">
          <mxGeometry height="30" width="30" x="610" y="1060" as="geometry" />
        </mxCell>
        <mxCell id="w6_end_dot" parent="1" style="ellipse;whiteSpace=wrap;html=1;fillColor=#000000;strokeColor=#000000;" value="" vertex="1">
          <mxGeometry height="14" width="14" x="618" y="1068" as="geometry" />
        </mxCell>
        <mxCell id="w6_t1" edge="1" parent="1" source="w6_start" style="endArrow=classic;html=1;fontSize=10;strokeColor=#6c8ebf;strokeWidth=2;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" target="w6_req" value="business MS sends&#xa;SUBSCRIBE request">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="w6_t2" edge="1" parent="1" source="w6_req" style="endArrow=classic;html=1;fontSize=10;strokeColor=#d6b656;strokeWidth=2;exitX=0.4;exitY=1;entryX=0.4;entryY=0;" target="w6_sub" value="&lt;b&gt;[refcount was 0]&lt;/b&gt;&#xa;first subscriber → send ReqMsg to LSEG">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="w6_t3" edge="1" parent="1" style="endArrow=classic;html=1;fontSize=10;strokeColor=#82b366;strokeWidth=2;exitX=0.85;exitY=1;entryX=0.85;entryY=0;" value="&lt;b&gt;[refcount &gt; 0]&lt;/b&gt;&#xa;already subscribed →&#xa;publish cached snapshot">
          <mxGeometry relative="1" x="0.5692" as="geometry">
            <mxPoint as="offset" />
            <mxPoint x="786.5" y="290" as="sourcePoint" />
            <mxPoint x="786.5" y="550" as="targetPoint" />
          </mxGeometry>
          <Array as="points">
            <mxPoint x="900" y="320" />
            <mxPoint x="900" y="500" />
          </Array>
        </mxCell>
        <mxCell id="w6_t4" edge="1" parent="1" source="w6_sub" style="endArrow=classic;html=1;fontSize=10;strokeColor=#82b366;strokeWidth=2;exitX=0.5;exitY=1;entryX=0.472;entryY=0.033;entryDx=0;entryDy=0;entryPerimeter=0;" target="w6_active" value="RefreshMsg received&#xa;(snapshot complete)">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="w6_t5" edge="1" parent="1" source="w6_sub" style="endArrow=classic;html=1;fontSize=10;strokeColor=#b85450;strokeWidth=2;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" target="w6_error" value="StatusMsg: DENIED /&#xa;NOT_FOUND / SUSPECT">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="w6_t6" edge="1" parent="1" source="w6_active" style="endArrow=classic;dashed=1;html=1;fontSize=10;strokeColor=#82b366;exitX=0;exitY=0.5;entryX=0;entryY=0.7;" target="w6_active" value="new SUBSCRIBE arrives&#xa;(refcount++)&#xa;[self-loop, no transition]">
          <mxGeometry relative="1" as="geometry" />
          <Array as="points">
            <mxPoint x="420" y="605" />
            <mxPoint x="420" y="635" />
          </Array>
        </mxCell>
        <mxCell id="w6_t7" edge="1" parent="1" source="w6_active" style="endArrow=classic;html=1;fontSize=10;strokeColor=#d79b00;strokeWidth=2;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" target="w6_drain" value="UNSUBSCRIBE arrives →&#xa;refcount reaches 0">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="w6_t8" edge="1" parent="1" source="w6_drain" style="endArrow=classic;dashed=1;html=1;fontSize=10;strokeColor=#82b366;exitX=1;exitY=0.3;entryX=1;entryY=0.7;" target="w6_active" value="new SUBSCRIBE during&#xa;drain → abort close">
          <mxGeometry relative="1" as="geometry" />
          <Array as="points">
            <mxPoint x="830" y="770" />
            <mxPoint x="830" y="650" />
          </Array>
        </mxCell>
        <mxCell id="w6_t9" edge="1" parent="1" source="w6_drain" style="endArrow=classic;html=1;fontSize=10;strokeColor=#666666;strokeWidth=2;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" target="w6_closed" value="grace period elapsed →&#xa;send CloseMsg to EMA">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="w6_t10" edge="1" parent="1" source="w6_error" style="endArrow=classic;dashed=1;html=1;fontSize=10;strokeColor=#b85450;exitX=0;exitY=0.5;entryX=1;entryY=0.5;" target="w6_req" value="retry after 60s&#xa;(transient error)">
          <mxGeometry relative="1" as="geometry" />
          <Array as="points">
            <mxPoint x="850" y="240" />
          </Array>
        </mxCell>
        <mxCell id="w6_t11" edge="1" parent="1" source="w6_closed" style="endArrow=classic;html=1;fontSize=10;strokeColor=#666666;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" target="w6_end" value="end of lifecycle">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="w6_legend" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f9f9f9;strokeColor=#333333;fontSize=10;align=left;spacingLeft=10;verticalAlign=middle;" value="&lt;b&gt;Notes&lt;/b&gt;&#xa;&#xa;•  refcount is stored in &lt;b&gt;subscription:refcount:{ric}&lt;/b&gt; (Redis), durable in &lt;b&gt;subscription_requests&lt;/b&gt; (PG)&#xa;•  Grace period in DRAINING (default 30s) prevents thrashing when a MS unsubscribes and another subscribes within a window&#xa;•  ERROR is logged to &lt;b&gt;subscription_audit&lt;/b&gt; with the StatusMsg payload; manual intervention required for permanent errors&#xa;•  On failover, all ACTIVE RICs return to SUBSCRIBING (Pod 2 re-sends ReqMsg using its warm EMA session)" vertex="1">
          <mxGeometry height="220" width="450" x="900" y="550" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram name="7. Workflow — Pod State / Leader Election" id="iQ78Cp8z_9SJnfxlXglu">
    <mxGraphModel dx="1144" dy="691" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1500" pageHeight="1150" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="w7_title" parent="1" style="text;html=1;align=left;verticalAlign=middle;fontSize=14;spacingLeft=10;" value="&lt;b&gt;Workflow — Pod State Machine (Leader Election)&lt;/b&gt;&#xa;Role assignment: pod-0 &amp; pod-1 = warm-eligible (open LSEG session even if not leader);  pod-2 &amp; pod-3 = cold (no LSEG session unless promoted)" vertex="1">
          <mxGeometry height="60" width="1400" x="40" y="20" as="geometry" />
        </mxCell>
        <mxCell id="w7_start" parent="1" style="ellipse;whiteSpace=wrap;html=1;fillColor=#000000;strokeColor=#000000;" value="" vertex="1">
          <mxGeometry height="30" width="30" x="725" y="100" as="geometry" />
        </mxCell>
        <mxCell id="w7_starting" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=11;align=center;" value="&lt;b&gt;STARTING&lt;/b&gt;&#xa;&#xa;JVM boot, Spring context load,&#xa;Redis &amp; PG connections established" vertex="1">
          <mxGeometry height="90" width="240" x="620" y="170" as="geometry" />
        </mxCell>
        <mxCell id="w7_competing" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;align=center;" value="&lt;b&gt;COMPETING&lt;/b&gt;&#xa;&#xa;Loop: attempt SETNX leader:lock {pod-id} EX 5&#xa;Inspect role config (warm-eligible / cold)" vertex="1">
          <mxGeometry height="90" width="240" x="620" y="310" as="geometry" />
        </mxCell>
        <mxCell id="w7_leader" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;align=center;fontStyle=1;" value="&lt;b&gt;🟢 LEADER&lt;/b&gt;&#xa;&#xa;Holds leader:lock&#xa;Opens EMA session (login #1)&#xa;Subscribes to all RICs in registry&#xa;Publishes ticks to Kafka&#xa;Renews lock every 2s" vertex="1">
          <mxGeometry height="140" width="240" x="80" y="470" as="geometry" />
        </mxCell>
        <mxCell id="w7_warm" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;align=center;fontStyle=1;" value="&lt;b&gt;🟡 WARM_STANDBY&lt;/b&gt;&#xa;&#xa;Lost election, role = warm-eligible&#xa;Opens EMA session (login #2)&#xa;NO subscriptions sent&#xa;Watches leader:lock TTL&#xa;Polls token from Redis" vertex="1">
          <mxGeometry height="140" width="240" x="620" y="470" as="geometry" />
        </mxCell>
        <mxCell id="w7_cold" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=11;align=center;" value="&lt;b&gt;⚪ COLD_STANDBY&lt;/b&gt;&#xa;&#xa;Lost election, role = cold-only&#xa;NO LSEG session, NO login charge&#xa;Watches leader:lock TTL&#xa;Ready to be promoted (cold path)" vertex="1">
          <mxGeometry height="140" width="240" x="1160" y="470" as="geometry" />
        </mxCell>
        <mxCell id="w7_degraded" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;align=center;" value="&lt;b&gt;⚠ DEGRADED&lt;/b&gt;&#xa;&#xa;EMA stream disconnected unexpectedly&#xa;(LSEG-side reset, transient network)&#xa;Reconnecting (EMA auto-reconnect + manual ReqMsg replay)&#xa;Lock still held — pod is leader but not serving" vertex="1">
          <mxGeometry height="140" width="240" x="80" y="700" as="geometry" />
        </mxCell>
