          <mxGeometry height="60" width="300" x="50" y="200" as="geometry" />
        </mxCell>
        <mxCell id="f_m2" edge="1" parent="1" style="endArrow=classic;dashed=1;html=1;fontSize=10;strokeColor=#b85450;strokeWidth=2;fontStyle=2;" value="&lt;b&gt;2.&lt;/b&gt; heartbeat STOPS (Pod 1 dead)">
