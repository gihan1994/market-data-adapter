<?xml version="1.0" encoding="UTF-8"?>
<!--
    LSEG EMA Java SDK configuration for on-prem TREP / RTDS.

    TREP topology (PRODUCTION):
      - TREP / RTDS exposed via a load balancer with 2 IPs (HA pair).
      - LB sits in front of 2 backend ADS servers (no hall1/hall2 concept on TREP side).
      - Both hall1 and hall2 OpenShift clusters connect to the SAME LB endpoints.
      - LB may fail one IP over to the single remaining IP if a backend ADS dies.
      - From the client perspective: ChannelSet of (trep-lb-1, trep-lb-2) gives client-side
        failover if the LB drops an IP. Same DACS session is replayed on the new channel —
        NO additional DACS login is opened.

    Channel host/port values here are placeholders — the actual endpoints come from
    application*.yml via OmmConsumerConfig.host() at runtime.

    Reference: EMAJ Configuration Guide §3.4.4 (RSSL_SOCKET) and §3.4.8 (ChannelSet).
-->
<EmaConfig>

    <ConsumerGroup>
        <DefaultConsumer value="Consumer_1"/>
        <ConsumerList>
            <Consumer>
                <Name value="Consumer_1"/>
                <!--
                  ChannelSet — EMA attempts Channel_TREP_LB_Primary first; on disconnect
                  it tries Channel_TREP_LB_Backup. LOGIN domain is replayed automatically
                  on the new channel using the same DACS credentials.
                -->
                <ChannelSet value="Channel_TREP_LB_Primary, Channel_TREP_LB_Backup"/>
                <Logger value="Logger_File"/>
                <Dictionary value="Dictionary_1"/>
                <XmlTraceToStdout value="0"/>
                <RestEnableLog value="0"/>

                <!-- Reconnection — unlimited attempts with exponential backoff -->
                <ReconnectAttemptLimit value="-1"/>
                <ReconnectMinDelay value="2000"/>
                <ReconnectMaxDelay value="30000"/>

                <RequestTimeout value="15000"/>
                <ItemCountHint value="500000"/>

                <!-- DACS LOGIN domain timeout -->
                <LoginRequestTimeOut value="45000"/>
            </Consumer>
        </ConsumerList>
    </ConsumerGroup>

    <ChannelGroup>
        <ChannelList>
            <!--
              Primary TREP LB endpoint — same value used in hall1 and hall2 configmaps.
              Override via application.yml: marketdata.lseg.ads-host / ads-port.
            -->
            <Channel>
                <Name value="Channel_TREP_LB_Primary"/>
                <ChannelType value="ChannelType::RSSL_SOCKET"/>
                <CompressionType value="CompressionType::None"/>
                <GuaranteedOutputBuffers value="5000"/>
                <ConnectionPingTimeout value="30000"/>
                <Host value="trep-lb-1.trep.local"/>
                <Port value="14002"/>
                <TcpNodelay value="1"/>
            </Channel>

            <!--
              Backup TREP LB endpoint — also the same in both halls.
              ChannelSet uses this if Primary is unreachable.
            -->
            <Channel>
                <Name value="Channel_TREP_LB_Backup"/>
                <ChannelType value="ChannelType::RSSL_SOCKET"/>
                <CompressionType value="CompressionType::None"/>
                <GuaranteedOutputBuffers value="5000"/>
                <ConnectionPingTimeout value="30000"/>
                <Host value="trep-lb-2.trep.local"/>
                <Port value="14002"/>
                <TcpNodelay value="1"/>
            </Channel>

            <!-- RTO cloud channel — only used when marketdata.lseg.connection-mode=RTO_CLOUD -->
            <Channel>
                <Name value="Channel_RTO"/>
                <ChannelType value="ChannelType::RSSL_ENCRYPTED"/>
                <EncryptedProtocolType value="EncryptedProtocolType::RSSL_SOCKET"/>
                <CompressionType value="CompressionType::None"/>
                <GuaranteedOutputBuffers value="5000"/>
                <ConnectionPingTimeout value="30000"/>
                <EnableSessionManagement value="1"/>
                <Location value="us-east-1"/>
            </Channel>
        </ChannelList>
    </ChannelGroup>

    <DictionaryGroup>
        <DictionaryList>
            <Dictionary>
                <Name value="Dictionary_1"/>
                <DictionaryType value="DictionaryType::ChannelDictionary"/>
            </Dictionary>
        </DictionaryList>
    </DictionaryGroup>

    <LoggerGroup>
        <LoggerList>
            <Logger>
                <Name value="Logger_File"/>
                <LoggerType value="LoggerType::Stdout"/>
                <LoggerSeverity value="LoggerSeverity::Warning"/>
            </Logger>
        </LoggerList>
    </LoggerGroup>

</EmaConfig>
