<?xml version="1.0" encoding="UTF-8"?>
<!--
    LSEG EMA Java SDK configuration.
    See: https://github.com/Refinitiv/Real-Time-SDK/blob/master/Java/Ema/Src/main/resources/EmaConfig.xml
    The OmmConsumerConfig.consumerName("Consumer_1") in OmmConsumerManager binds to this file.

    For RTO (Real-Time Optimized) over the internet, use Channel_RTO with EncryptedProtocolType=RSSL_SOCKET.
    Service discovery is performed automatically by the SDK using OAuth V2 client credentials.
-->
<EmaConfig>

    <ConsumerGroup>
        <DefaultConsumer value="Consumer_1"/>
        <ConsumerList>
            <Consumer>
                <Name value="Consumer_1"/>
                <Channel value="Channel_RTO"/>
                <Logger value="Logger_File"/>
                <Dictionary value="Dictionary_1"/>
                <RestEnableLog value="0"/>
                <XmlTraceToStdout value="0"/>
                <!-- Reconnection -->
                <ReconnectAttemptLimit value="-1"/>          <!-- -1 = unlimited -->
                <ReconnectMinDelay value="2000"/>            <!-- ms -->
                <ReconnectMaxDelay value="30000"/>
                <RequestTimeout value="15000"/>
                <ItemCountHint value="500000"/>
            </Consumer>
        </ConsumerList>
    </ConsumerGroup>

    <ChannelGroup>
        <ChannelList>
            <!-- Refinitiv Real-Time Optimized (cloud) using OAuth V2 client credentials -->
            <Channel>
                <Name value="Channel_RTO"/>
                <ChannelType value="ChannelType::RSSL_ENCRYPTED"/>
                <EncryptedProtocolType value="EncryptedProtocolType::RSSL_SOCKET"/>
                <CompressionType value="CompressionType::None"/>
                <GuaranteedOutputBuffers value="5000"/>
                <ConnectionPingTimeout value="30000"/>
                <EnableSessionManagement value="1"/>          <!-- enables OAuth + service discovery -->
                <Location value="us-east-1"/>                 <!-- pick region close to deployment -->
                <ObjectName value=""/>
            </Channel>

            <!-- Direct RSSL socket (used with on-prem ADS) -->
            <Channel>
                <Name value="Channel_RSSL"/>
                <ChannelType value="ChannelType::RSSL_SOCKET"/>
                <CompressionType value="CompressionType::None"/>
                <GuaranteedOutputBuffers value="5000"/>
                <ConnectionPingTimeout value="30000"/>
                <Host value="localhost"/>
                <Port value="14002"/>
            </Channel>
        </ChannelList>
    </ChannelGroup>

    <DictionaryGroup>
        <DictionaryList>
            <Dictionary>
                <Name value="Dictionary_1"/>
                <DictionaryType value="DictionaryType::ChannelDictionary"/>
            </Dictionary>
        </DictionaryList>
    </DictionaryGroup>

    <LoggerGroup>
        <LoggerList>
            <Logger>
                <Name value="Logger_File"/>
                <LoggerType value="LoggerType::Stdout"/>
                <LoggerSeverity value="LoggerSeverity::Warning"/>
            </Logger>
        </LoggerList>
    </LoggerGroup>

</EmaConfig>
